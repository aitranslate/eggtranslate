{
  "name": "eggtranslate",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && cross-env BUILD_MODE=prod vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "preview:lan": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "node e2e/run.mjs",
    "test:e2e:mobile": "node e2e/run-mobile.mjs",
    "test:e2e:live": "node e2e/run.mjs --live",
    "test:e2e:live-full": "node e2e/run-live.mjs",
    "test:e2e:install": "npm install -g agent-browser && agent-browser install"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@tanstack/react-virtual": "^3.13.26",
    "assemblyai": "^4.23.0",
    "framer-motion": "^12.23.12",
    "jsonrepair": "^3.13.0",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.364.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.2",
    "sentence-splitter": "^5.0.1",
    "srt-parser-2": "^1.2.3",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.1.1",
    "postcss": "8.4.49",
    "tailwindcss": "v3.4.16",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vite-plugin-source-info": "^1.0.0",
    "vitest": "^4.1.7"
  }
}