# Optional: real LLM translation during E2E (custom OpenAI-compatible)
# Multiple keys: use | for load balancing, e.g. key1|key2
E2E_LLM_BASE_URL=https://api.mistral.ai/v1
E2E_LLM_API_KEY=your-key-1|your-key-2
E2E_LLM_MODEL=mistral-small-latest

# Optional overrides
# E2E_BASE_URL=http://127.0.0.1:5173
# E2E_PORT=5173
# E2E_HEADED=0
# E2E_SKIP_SERVER=0
